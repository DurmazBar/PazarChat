# =============================================================================
# PazarChat — Web Environment Variables
# =============================================================================
# Bu dosyayı `.env.local` olarak kopyala ve gerçek değerleri doldur.
# Next.js .env.local'i otomatik okur; .env.local Vercel'de set edilir.
# `NEXT_PUBLIC_*` prefix'i client-side'a expose eder (anon key güvenli).
# =============================================================================

# Supabase (public — anon key)
NEXT_PUBLIC_SUPABASE_URL=https://wgtgbrufzuzjtqhrojjo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Telegram bot URL'i (CTA butonları için)
NEXT_PUBLIC_BOT_URL=https://t.me/KO_PazarChat_bot

# Site URL (canonical, og:image vs.)
NEXT_PUBLIC_SITE_URL=https://pazarchat.com
