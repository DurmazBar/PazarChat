# =============================================================================
# PazarChat — PC Service Environment Variables
# =============================================================================
# Bu dosyayı `.env` olarak kopyala ve gerçek değerleri doldur.
# `.env` dosyası asla git'e commit edilmemeli (.gitignore'da listeli).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://wgtgbrufzuzjtqhrojjo.supabase.co

# anon public key (RLS bypass etmez, kullanıcı auth gerektirir)
# PC servisi `licenses.api_key` ile kimlik doğrular, anon key sadece bağlantı için.
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Lisans (PazarChat API key)
# -----------------------------------------------------------------------------
# Telegram bot'tan /davetiye CODE ile aldığın "pzc_..." formatlı key
PAZARCHAT_API_KEY=

# -----------------------------------------------------------------------------
# Knight Online Ayarları
# -----------------------------------------------------------------------------
# KO penceresinin başlığında geçen kısmi metin (büyük/küçük harf duyarsız)
# Genelde: "Knight OnLine Client" veya "KnightOnLine"
KO_WINDOW_TITLE=Knight OnLine Client

# Karakterin oyun içi adı (yakalanan PM'ler bu karaktere ait olarak kaydedilir)
KO_CHARACTER_NAME=

# Sunucu adı (opsiyonel, sadece UI'da gösterim için)
KO_SERVER_NAME=Cypher

# -----------------------------------------------------------------------------
# OCR Ayarları
# -----------------------------------------------------------------------------
# Screenshot alma sıklığı (saniye). 1.0-2.0 önerilir.
OCR_INTERVAL_SECONDS=1.5

# EasyOCR GPU kullansın mı? (NVIDIA + CUDA varsa True yap, 5-10x hızlanır)
# Yoksa CPU üzerinde çalışır, daha yavaş ama çalışır.
OCR_USE_GPU=False

# Tarama yapılacak ekran bölgesi (otomatik tespit başarısızsa override)
# Boş bırakırsa window_manager otomatik chat alanını bulur.
# Format: "x,y,width,height" — örn: "10,650,800,180"
OCR_CROP_REGION=

# -----------------------------------------------------------------------------
# Çalışma Davranışı
# -----------------------------------------------------------------------------
# Heartbeat aralığı (saniye) — PC bağlı durumunun bot'ta gösterilmesi için
HEARTBEAT_INTERVAL_SECONDS=60

# Duplicate PM filtresi için son N mesajı hatırla
DUPLICATE_WINDOW_SIZE=50

# -----------------------------------------------------------------------------
# Cevap Gönderim Modu — KRITIK SEÇIM
# -----------------------------------------------------------------------------
# PazarChat üç farklı paste modu sunar. Knight Online TOS açısından farklı
# risk seviyelerine sahiptirler. KULLANIM SORUMLULUĞU TAMAMEN SIZINDIR.
#
# Modlar:
#
#   manual  → En güvenli. Pano'ya yazılır, hiçbir tuş simülasyonu yapılmaz.
#             Sen KO'ya geçip Ctrl+V + Enter ile gönderirsin.
#             TOS riski: Minimum (Discord ekran paylaşımı + dikteyle eşdeğer)
#
#   hybrid  → Orta. Pano'ya yazılır + F8 hotkey aktif.
#             Sen KO'da F8 basınca otomatik yapıştırılır + Enter.
#             SADECE KO penceresi aktifken çalışır.
#             TOS riski: Düşük (kullanıcı tetikli, manuel fiziksel tuş)
#
#   auto    → ⚠ EN RİSKLİ. Cevap geldiği anda PC servisi otomatik olarak
#             KO penceresini foreground'a alır ve yapıştırır.
#             Kullanıcı tetiği yok → keyboard simulation kategorisinde sayılabilir.
#             Knight Online TOS'unda "automation tool" olarak değerlendirilebilir.
#             KULLANIM SORUMLULUĞU SIZE AITTIR. Banlanma riski mevcuttur.
#             Avukat tavsiyesi olmadan production'da KULLANMAYIN.
#
PASTE_MODE=hybrid

# Hotkey tuşu (hybrid + auto modlarında kullanılır)
HOTKEY_PASTE_KEY=f8

# Auto mode'da PC penceresi geçişi sonrası bekleme (ms) — pencere focus'unun
# kararlı olması için. Düşük değer kararsızlık, yüksek değer yavaşlık.
AUTO_PASTE_DELAY_MS=200

# Log seviyesi: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Log dosyası yolu (relatif veya absolute). Boş ise sadece stdout.
LOG_FILE=logs/pazarchat.log
