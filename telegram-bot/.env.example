# =============================================================================
# PazarChat — Telegram Bot Environment Variables
# =============================================================================
# Bu dosyayı `.env` olarak kopyala ve gerçek değerleri doldur.
# `.env` dosyası asla git'e commit edilmemeli.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
# BotFather'dan al: https://t.me/BotFather → /newbot → bot adı: KO_PazarChat
# Token format: 1234567890:ABCdefGHIjkl...
TELEGRAM_BOT_TOKEN=

# Bot kullanıcı adı (sadece UI mesajlarında geçer, @ olmadan)
TELEGRAM_BOT_USERNAME=KO_PazarChat_bot

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://wgtgbrufzuzjtqhrojjo.supabase.co

# service_role key — bot sunucuda çalışır, kullanıcı erişmez.
# DİKKAT: Bu key RLS bypass eder, admin yetkisi var. Asla istemciye gitmesin.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Admin Yetkileri
# -----------------------------------------------------------------------------
# Admin Telegram chat_id'leri (virgülle ayrılmış).
# Bu kullanıcılar /davetiye_olustur gibi admin komutlarını çalıştırabilir.
# Kendi chat_id'ni bulmak için: @userinfobot'a /start yaz, gelen ID'yi buraya koy.
ADMIN_TELEGRAM_CHAT_IDS=

# -----------------------------------------------------------------------------
# Çalışma Davranışı
# -----------------------------------------------------------------------------
# Yeni incoming PM polling aralığı (saniye)
INCOMING_POLL_INTERVAL=2

# Tek PM bildirimi için max kaç karakter göster (kesilirse "..." eklenir)
PM_PREVIEW_MAX_CHARS=200

# Bot dummy email format (Supabase auth.users için)
# {chat_id} → chat_id ile değiştirilir
INTERNAL_EMAIL_DOMAIN=tg.pazarchat.internal

# -----------------------------------------------------------------------------
# Loglama
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=
